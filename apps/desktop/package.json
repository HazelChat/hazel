{
	"name": "desktop",
	"private": true,
	"type": "module",
	"module": "src/bun/index.ts",
	"scripts": {
		"dev": "electrobun dev --watch",
		"start": "electrobun run",
		"build:web:desktop": "bun run --cwd ../web build:desktop",
		"build": "electrobun build --env=stable",
		"build:canary": "electrobun build --env=canary",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hazel/domain": "workspace:*",
		"electrobun": "^1.14.4"
	},
	"devDependencies": {
		"@types/bun": "1.3.8",
		"@types/node": "^24.7.2",
		"typescript": "^5.9.3"
	}
}
